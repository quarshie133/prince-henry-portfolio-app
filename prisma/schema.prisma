generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  type      String // "poetry" or "story"
  published     Boolean  @default(false)
  featuredImage String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteSettings {
  id         String   @id @default("singleton")
  heroTitle  String   @default("Words that resonate, stories that endure.")
  heroSub    String   @default("Welcome to my digital garden. I write about poetry, technology, and the spaces in between.")
  aboutText  String   @default("Hello. I'm a writer bridging the gap between digital thoughts and tangible feelings.")
  aboutImage String?
  instagram  String?
  twitter    String?
  facebook   String?
  tiktok     String?
  snapchat   String?
  whatsapp   String?  @default("+233 55 659 7805")
  updatedAt  DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
